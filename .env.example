# Django Secret Key
# Generate a new secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Debug mode (True/False)
DEBUG=True

# Allowed hosts (comma-separated, leave empty for development)
ALLOWED_HOSTS=127.0.0.1,localhost,10.242.221.0

# Database settings
# For SQLite (default):
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# For PostgreSQL (uncomment and configure if needed):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# Internationalization
LANGUAGE_CODE=ru-ru
TIME_ZONE=Europe/Moscow
